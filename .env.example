# Stellar network to connect to: "testnet" | "mainnet"
VITE_STELLAR_NETWORK=testnet

# Soroban RPC endpoint for the chosen network
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Backend REST API base URL (no trailing slash)
VITE_BACKEND_API_URL=http://localhost:3000

# Deployed Soroban contract address
VITE_CONTRACT_ADDRESS=

# Google OAuth client ID (used by @react-oauth/google)
VITE_GOOGLE_CLIENT_ID=

# GitHub repo used to fetch the contributors carousel (owner/repo format).
# Defaults to Riddlrealm/Mindmint-Frontend when omitted.
VITE_CONTRIBUTORS_REPO=Riddlrealm/Mindmint-Frontend
